{{ ansible_managed | comment }}
# Generated by roles/resolver from `headscale nodes list --output json` on the
# core node (docs/architecture.md section 8, "Generated" flow). hosts-plugin
# format: <ip> <fqdn>. Each tailnet node's IPv4 is mapped to
# <given-name>.{{ substrate_domain }}. Regenerated every reconcile; membership
# changes track automatically. Service aliases and rich records (CNAME/SRV/TXT
# that MagicDNS can't express) belong in a separate hand-maintained zone, not
# here — this file is overwritten wholesale.
#
# Idempotence: nodes are sorted by name and only the first IPv4 per node is
# emitted, so identical membership renders byte-identical output.
{% for node in resolver_nodes | sort(attribute='given_name') %}
{%   set name = node.given_name | default(node.name) | default('') %}
{%   set v4 = (node.ip_addresses | default([]) | select('match', '^[0-9]+\\.') | list) %}
{%   if name | length > 0 and v4 | length > 0 %}
{{ v4[0] }} {{ name }}.{{ substrate_domain }}
{%   endif %}
{% endfor %}
