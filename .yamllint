---
extends: default

ignore: |
  .git/
  *.j2
  # SOPS-encrypted secrets are ciphertext, not hand-authored YAML to format.
  secrets/

rules:
  line-length:
    max: 160
    level: warning
  truthy:
    allowed-values: ["true", "false"]
    check-keys: false
  comments:
    min-spaces-from-content: 1
  document-start:
    present: true
    level: warning
  # Keep this config compatible with ansible-lint's embedded yamllint rules so
  # the two tools agree (avoids the "incompatible custom yamllint" warning).
  comments-indentation: false
  braces:
    max-spaces-inside: 1
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
